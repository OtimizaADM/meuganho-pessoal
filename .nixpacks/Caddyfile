{
        admin off
        persist_config off
        auto_https off
        log {
                format json
        }
        servers {
                trusted_proxies static private_ranges 100.0.0.0/8
        }
}
:{$PORT:3000} {
        log {
                format json
        }
        handle /pessoal/* {
                root * /app/dist/public
                encode gzip
                file_server
                try_files {path} /pessoal/index.html
        }
        handle /api/* {
                reverse_proxy localhost:3001
        }
}
